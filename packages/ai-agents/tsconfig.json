{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "database": ["../database/src"]
    }
  },
  "include": ["src/**/*", "check-env.ts"],
  "exclude": ["node_modules", "dist"]
}
